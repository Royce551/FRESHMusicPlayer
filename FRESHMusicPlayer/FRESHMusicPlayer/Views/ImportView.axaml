<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:FRESHMusicPlayer.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="FRESHMusicPlayer.Views.ImportView" Background="{DynamicResource BackgroundColor}"
             x:DataType="vm:ImportViewModel">
  <Design.DataContext>
    <vm:ImportViewModel/>
  </Design.DataContext>
  <StackPanel Margin="20" Spacing="5">
       <AdornerLayer.Adorner>
		<Panel x:Name="DropPrompt" IsVisible="{Binding MainView.ShowDragDropOverlay}" IsHitTestVisible="False">
			<Rectangle Fill="{DynamicResource BackgroundColor}" Opacity="0.5"/>
            <TextBlock Text="Drop here to import" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Panel>
    </AdornerLayer.Adorner>

      <TextBlock Text="Import" FontWeight="Bold" FontSize="20"/>
      <Button Content="Browse for tracks" Command="{Binding BrowseTracks}"/>
      <Button Content="Browse for folders" Command="{Binding BrowseFolders}"/>
  </StackPanel>
</UserControl>
