<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:FRESHMusicPlayer.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="FRESHMusicPlayer.Views.AlbumsView" Background="{DynamicResource BackgroundColor}"
             x:DataType="vm:AlbumsViewModel">
  <Design.DataContext>
    <vm:TracksViewModel/>
  </Design.DataContext>

  <Grid ColumnDefinitions="222,5,*">
    <ListBox Grid.Column="0" Width="" Background="{DynamicResource SecondaryColor}" IsTextSearchEnabled="True" BorderBrush="Transparent" ItemsSource="{Binding Albums}" SelectedItem="{Binding SelectedAlbum}">
      <ListBox.ItemsPanel>
        <ItemsPanelTemplate>
          <VirtualizingStackPanel/>
        </ItemsPanelTemplate>
      </ListBox.ItemsPanel>
      <ListBox.ItemTemplate>
        <DataTemplate>
          <StackPanel Orientation="Horizontal" Margin="5,2" Spacing="10">
            <Image Source="{Binding CoverArt^}" Width="24" Height="24" RenderOptions.BitmapInterpolationMode="HighQuality"/>
            <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
          </StackPanel>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>
    <GridSplitter Grid.Column="1" ResizeDirection="Columns" Background="{DynamicResource SecondaryColor}" Foreground="Transparent" BorderBrush="Transparent"/>
    <DockPanel Grid.Column="2">
      <DockPanel DockPanel.Dock="Bottom" LastChildFill="False">
        <TextBlock Text="{Binding FooterText}" FontSize="12" Foreground="{DynamicResource SecondaryTextColor}" Margin="10,0,0,0" VerticalAlignment="Center" DockPanel.Dock="Left"/>
        <Button Content="Play all" Command="{Binding PlayAll}" DockPanel.Dock="Right" Margin="0,10,10,10"/>
        <Button Content="Enqueue all" Command="{Binding EnqueueAll}" DockPanel.Dock="Right" Margin="0,10,10,10"/>
      </DockPanel>

      <ListBox x:Name="MainListBox" ItemsSource="{Binding Tracks}" BorderBrush="Transparent" SelectionChanged="ListBox_SelectionChanged" Grid.IsSharedSizeScope="True">
        <ListBox.ItemsPanel>
          <ItemsPanelTemplate>
            <VirtualizingStackPanel/>
          </ItemsPanelTemplate>
        </ListBox.ItemsPanel>
        <ListBox.DataTemplates>
          <DataTemplate DataType="vm:DatabaseTrackViewModel">
            <Grid RowDefinitions="*,*" Margin="5,0" Background="Transparent">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" SharedSizeGroup="TrackNumber"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <Grid.Styles>
                <Style Selector="Grid > StackPanel > Button">
                  <Setter Property="IsVisible" Value="False"/>
                </Style>
                <Style Selector="Grid:pointerover > StackPanel > Button">
                  <Setter Property="IsVisible" Value="True"/>
                </Style>
              </Grid.Styles>

              <TextBlock Text="{Binding TrackNumber}" Grid.RowSpan="2" VerticalAlignment="Center" Margin="0,0,8,0" HorizontalAlignment="Center"/>
              <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Title}" FontSize="12"/>
              <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ArtistAlbumLabel}" FontSize="9" Foreground="{DynamicResource SecondaryTextColor}"/>
              <StackPanel Grid.Row="0" Grid.RowSpan="2" Grid.Column="2" HorizontalAlignment="Right" Orientation="Horizontal" Spacing="10">
                <Button Content="Play" Command="{Binding Play}"/>
                <Button Content="Enqueue" Command="{Binding Enqueue}"/>
                <Button Content="Delete"/>
              </StackPanel>

              <Grid.ContextMenu>
                <ContextMenu>
                  <MenuItem Header="Play next" Command="{Binding PlayNext}"/>
                  <MenuItem Header="Open in File Explorer" Command="{Binding OpenInFileExplorer}"/>
                </ContextMenu>
              </Grid.ContextMenu>
            </Grid>
          </DataTemplate>
        </ListBox.DataTemplates>
      </ListBox>
    </DockPanel>
  </Grid>
  
</UserControl>
